{
  "name": "amaceit-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:proxy": "local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem",
    "build": "next build",
    "build:local": "npm run build && cp -r ./.next/static ./.next/standalone/.next/static && cp -r ./public ./.next/standalone/public",
    "start": "echo 'Provide the STORYBLOK_API_TOKEN' && read token && STORYBLOK_API_TOKEN=$token node ./.next/standalone/server",
    "start:debug": "next start",
    "test": "jest --watch",
    "test:ci": "jest",
    "lint": "next lint",
    "format": "prettier --check --ignore-path .gitignore .",
    "sb-types:fetch": "storyblok pull-components --space 255438",
    "sb-types:generate": "storyblok-generate-ts source=./components.255438.json target=./component-types-sb",
    "storybook": "storybook dev -p 6006",
    "storybook:static:build": "storybook build",
    "storybook:static:start": "npx serve ./storybook-static -l 6006"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@storyblok/react": "^2.4.7",
    "dompurify": "^3.0.6",
    "framer-motion": "^10.16.7",
    "next": "^14.0.3",
    "react": "^18",
    "react-dom": "^18",
    "react-responsive": "^9.0.2",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@storybook/addon-designs": "^7.0.5",
    "@storybook/addon-essentials": "^7.6.1",
    "@storybook/addon-interactions": "^7.6.1",
    "@storybook/addon-links": "^7.6.1",
    "@storybook/addon-onboarding": "^1.0.8",
    "@storybook/blocks": "^7.6.1",
    "@storybook/nextjs": "^7.6.1",
    "@storybook/react": "^7.6.1",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.10",
    "@types/node": "20.10.0",
    "@types/react": "18.2.39",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-next": "14.0.3",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-storybook": "^0.6.15",
    "eslint-plugin-unused-imports": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "storyblok-generate-ts": "^2.0.1",
    "storybook": "^7.6.1",
    "tailwindcss": "^3.3.5",
    "typescript": "5.3.2"
  },
  "packageManager": "yarn@4.0.1"
}
