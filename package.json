{
  "name": "amaceit-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:proxy": "local-ssl-proxy --source 3010 --target 3000 --cert certificates/localhost.pem --key certificates/localhost-key.pem",
    "build": "next build",
    "build:local": "npm run build && cp -r ./.next/static ./.next/standalone/.next/static && cp -r ./public ./.next/standalone/public",
    "start": "echo 'Provide the STORYBLOK_API_TOKEN' && read token && STORYBLOK_API_TOKEN=$token node ./.next/standalone/server",
    "start:debug": "next start",
    "clean:nextCach": "npx rimraf .next",
    "test": "jest --watch",
    "test:ci": "jest",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --ui",
    "lint": "next lint",
    "format": "prettier --check --ignore-path .gitignore .",
    "sb-types:fetch": "storyblok pull-components --space 255438",
    "sb-types:generate": "storyblok-generate-ts source=./components.255438.json target=./component-types-sb",
    "storybook": "storybook dev -p 6006",
    "storybook:static:build": "storybook build",
    "storybook:static:start": "npx serve ./storybook-static -l 6006"
  },
  "dependencies": {
    "@azure/communication-email": "^1.0.0",
    "@heroicons/react": "^2.0.18",
    "@storyblok/react": "^3.0.14",
    "axios": "^1.6.7",
    "dompurify": "^3.0.6",
    "express-session": "^1.17.3",
    "framer-motion": "^11.5.4",
    "mailtrap": "^3.4.0",
    "next": "^14.1.0",
    "nookies": "^2.5.2",
    "passport": "^0.7.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.49.0",
    "react-responsive": "^10.0.0",
    "react-slick": "^0.30.2",
    "sharp": "^0.33.0",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@storybook/addon-actions": "^8.2.9",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-interactions": "^8.2.9",
    "@storybook/addon-links": "^8.2.9",
    "@storybook/addon-onboarding": "^8.2.9",
    "@storybook/blocks": "^8.2.9",
    "@storybook/nextjs": "^8.2.9",
    "@storybook/react": "^8.2.9",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.0.1",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/cookie": "^0.6.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.10",
    "@types/node": "^22.5.4",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18",
    "@types/react-slick": "^0.23.13",
    "autoprefixer": "^10",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.9",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-unused-imports": "^4.1.3",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemailer": "^6.9.7",
    "postcss": "^8",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "storyblok-generate-ts": "^2.0.1",
    "storybook": "^8.2.9",
    "tailwindcss": "^3.3.5",
    "typescript": "5.3.2"
  },
  "packageManager": "yarn@4.0.1"
}
